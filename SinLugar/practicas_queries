--  pruebas de group by

SELECT 
	students.name,
	courses.course_name
FROM 
	students
JOIN
	enrollments
ON 
	students.student_id = enrollments.student_id
JOIN courses
ON 
	enrollments.course_id = courses.course_id
GROUP by course_name;

-- aqui nos referimos con 1 a la primera columna en el select
SELECT 
	students.name,
	courses.course_name
FROM 
	students
JOIN
	enrollments
ON 
	students.student_id = enrollments.student_id
JOIN courses
ON 
	enrollments.course_id = courses.course_id
GROUP by 1; -- == students.name

-- practicando subconsultas

SELECT * FROM students
WHERE student_id = (
	SELECT student_id FROM enrollments WHERE enrollments.student_id = 1
);
